{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Projgen Docs",
  "description": "Template-driven project scaffolding with Projgen.",
  "colors": {
    "primary": "#7ddacf",
    "light": "#7ddacf",
    "dark": "#7ddacf"
  },
  "favicon": "/assets/logo/favicon.svg",
  "styling": {
    "codeblocks": {
      "theme": "material-theme-darker"
    },
    "eyebrows": "breadcrumbs"
  },
  "navigation": {
    "products": [
      {
        "product": "Projgen CLI",
        "description": "The Projgen command-line interface for running templates and managing the local registry.",
        "icon": "terminal",
        "versions": [
          {
            "version": "v3",
            "tag": "Latest",
            "default": true,
            "tabs": [
              {
                "tab": "Documentation",
                "icon": "square-library",
                "groups": [
                  {
                    "group": "Get started",
                    "icon": "play",
                    "pages": ["index", "introduction", "quickstart"]
                  },
                  {
                    "group": "Core concepts",
                    "icon": "lightbulb",
                    "pages": [
                      "core/concepts/what-is-projgen",
                      "core/concepts/templates-and-registry",
                      "core/concepts/template-vs-template-engine"
                    ]
                  },
                  {
                    "group": "CLI commands",
                    "icon": "square-terminal",
                    "pages": [
                      "core/cli/create",
                      "core/cli/add",
                      "core/cli/list",
                      "core/cli/remove"
                    ]
                  },
                  {
                    "group": "Configuration & registry",
                    "icon": "settings-2",
                    "pages": [
                      "core/configuration/registry",
                      "core/configuration/template-locations"
                    ]
                  },
                  {
                    "group": "Development",
                    "icon": "wrench",
                    "pages": [
                      "core/development/overview",
                      "core/development/project-structure",
                      "core/development/contributing"
                    ]
                  },
                  {
                    "group": "Releases",
                    "icon": "history",
                    "pages": ["core/changelog", "core/roadmap"]
                  }
                ]
              },
              {
                "tab": "Template spec",
                "icon": "square-terminal",
                "groups": [
                  {
                    "group": "Overview",
                    "icon": "sparkles",
                    "expanded": true,
                    "pages": [
                      "core/template-spec/introduction",
                      "core/template-spec/template-metadata"
                    ]
                  },
                  {
                    "group": "Variables",
                    "icon": "list-checks",
                    "pages": ["core/template-spec/variables"]
                  },
                  {
                    "group": "Steps",
                    "icon": "workflow",
                    "pages": [
                      "core/template-spec/steps/run",
                      "core/template-spec/steps/write",
                      "core/template-spec/steps/patch-text",
                      "core/template-spec/steps/patch-json",
                      "core/template-spec/steps/conditional-execution"
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "product": "Template Engine",
        "description": "The JSON-based template execution engine powering Projgen.",
        "icon": "cpu",
        "versions": [
          {
            "version": "v3.1",
            "tag": "Latest",
            "default": true,
            "groups": [
              {
                "group": "Overview",
                "icon": "sparkles",
                "pages": [
                  "template-engine/overview",
                  "template-engine/architecture"
                ]
              },
              {
                "group": "Execution model",
                "icon": "workflow",
                "pages": [
                  "template-engine/execution-flow",
                  "template-engine/error-handling"
                ]
              },
              {
                "group": "Versioning & migration",
                "icon": "git-branch",
                "pages": [
                  "template-engine/versioning",
                  "template-engine/migration/v3.0-to-v3.1"
                ]
              }
            ]
          },
          {
            "version": "v3.0",
            "tag": "Previous",
            "groups": [
              {
                "group": "Overview",
                "icon": "sparkles",
                "pages": ["template-engine/v3.0/overview"]
              },
              {
                "group": "Versioning & migration",
                "icon": "git-branch",
                "pages": ["template-engine/v3.0/compatibility"]
              }
            ]
          }
        ]
      },
      {
        "product": "Official Templates",
        "description": "Official Projgen templates maintained in the Projgen/templates registry.",
        "icon": "layers",
        "groups": [
          {
            "group": "Get started",
            "icon": "play",
            "pages": ["templates/overview", "templates/registry-usage"]
          },
          {
            "group": "Templates",
            "icon": "files",
            "pages": [
              "templates/sample-template",
              "templates/node-ts-yargs-cli"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub Core",
          "href": "https://github.com/Projgen/core",
          "icon": "github"
        },
        {
          "anchor": "GitHub Templates",
          "href": "https://github.com/Projgen/templates",
          "icon": "github"
        },
        {
          "anchor": "NPM CLI",
          "href": "https://www.npmjs.com/package/@projgen/cli",
          "icon": "box"
        }
      ]
    }
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "github",
      "label": "Projgen/Core",
      "href": "https://github.com/Projgen/core"
    }
  },
  "logo": {
    "dark": "/assets/logo/favicon.svg",
    "light": "/assets/logo/favicon.svg"
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Projgen"
    }
  },
  "background": {
    "decoration": "windows",
    "color": {
      "dark": "#00000f"
    }
  },
  "integrations": {
    "telemetry": {
      "enabled": true
    }
  },
  "contextual": {
    "options": [
      "chatgpt",
      "claude",
      "perplexity",
      "grok",
      "cursor",
      "vscode",
      "copy",
      "mcp"
    ]
  },
  "icons": {
    "library": "lucide"
  },
  "interaction": {
    "drilldown": true
  }
}
